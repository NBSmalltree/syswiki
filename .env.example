# ============================================================
# SysWiki 环境变量配置模板
# 复制本文件为 .env，填写实际值后使用
# 使用方法：cp .env.example .env && vi .env && source .env
# ============================================================

# ---- JWT 配置（必需） ----
# JWT 签名密钥（至少 32 字节，不满足则启动失败）
# 生成方法：openssl rand -hex 32
JWT_SECRET=your-jwt-secret-key-at-least-32-bytes

# ---- AI 配置（必需） ----
# AI 服务 API 地址（OpenAI 兼容协议，如 https://api.openai.com/v1）
AI_BASE_URL=https://api.openai.com/v1

# AI 服务 API Key（必须）
AI_API_KEY=your-ai-api-key

# ---- AI 模型配置（可选，有默认值） ----
# AI 快速问答模型名称（默认 mimo-v2.5-pro）
# AI_FLASH_MODEL=mimo-v2.5-pro

# AI 深度推理模型名称（默认 mimo-v2.5-pro）
# AI_THINK_MODEL=mimo-v2.5-pro

# ---- 数据库配置（可选，生产环境使用） ----
# 数据库密码（在 application-prod.yml 中通过 ${DB_PASSWORD} 引用）
# DB_PASSWORD=your-database-password

# ---- CORS 配置（可选，有默认值） ----
# 允许跨域访问的来源域名，多个用逗号分隔（开发环境默认 http://localhost:3000）
# 生产环境请配置为实际的 Nginx 域名，如：https://syswiki.bank.com
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- AI Embedding 配置（可选，默认复用 AI 配置） ----
# Embedding 模型名称（默认 text-embedding-3-small）
# EMBEDDING_MODEL=text-embedding-3-small

# Embedding 服务地址（默认同 AI_BASE_URL）
# EMBEDDING_BASE_URL=https://api.openai.com/v1

# Embedding 服务 API Key（默认同 AI_API_KEY）
# EMBEDDING_API_KEY=your-embedding-api-key

# ---- 分布式部署配置（可选，有默认值） ----
# 当前实例编号（多实例部署时各实例配置不同值 0-999，默认 0）
# WORKER_ID=0
# 异步任务核心线程数（默认 2）
# ASYNC_CORE_POOL_SIZE=2

# 异步任务最大线程数（默认 4）
# ASYNC_MAX_POOL_SIZE=4

# 异步任务队列容量（默认 100）
# ASYNC_QUEUE_CAPACITY=100

# ---- 异步重试配置（可选，有默认值） ----
# 向量同步失败时最大重试次数（默认 3）
# ASYNC_RETRY_MAX_ATTEMPTS=3

# 首次重试等待毫秒数（默认 1000）
# ASYNC_RETRY_INITIAL_BACKOFF=1000

# 重试等待时间倍增系数（默认 2.0）
# ASYNC_RETRY_MULTIPLIER=2.0

# 重试等待最大毫秒数（默认 10000）
# ASYNC_RETRY_MAX_BACKOFF=10000
